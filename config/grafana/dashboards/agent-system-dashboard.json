{
  "dashboard": {
    "id": null,
    "title": "Multi-Agent System Dashboard",
    "tags": ["agent-system"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Agent Activity",
        "type": "graph",
        "targets": [
          {
            "expr": "SELECT count(\"success\") FROM \"agent_actions\" WHERE time > now() - 1h GROUP BY time(5m) fill(0)",
            "format": "time_series",
            "legendFormat": "Actions per 5min"
          }
        ],
        "xAxis": {
          "show": true
        },
        "yAxes": [
          {
            "label": "Count",
            "show": true
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Message Flow",
        "type": "graph",
        "targets": [
          {
            "expr": "SELECT count(\"priority\") FROM \"hierarchy_messages\" WHERE time > now() - 1h GROUP BY time(5m), \"message_type\" fill(0)",
            "format": "time_series",
            "legendFormat": "{{message_type}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Agent Belief Updates",
        "type": "graph",
        "targets": [
          {
            "expr": "SELECT mean(\"confidence\") FROM \"agent_beliefs\" WHERE time > now() - 1h GROUP BY time(5m) fill(previous)",
            "format": "time_series",
            "legendFormat": "Average Confidence"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Goal Achievement Rate",
        "type": "singlestat",
        "targets": [
          {
            "expr": "SELECT count(\"priority\") FROM \"agent_goals\" WHERE \"event_type\" = 'achieved' AND time > now() - 1h",
            "format": "table"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s"
  }
}